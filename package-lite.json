{
  "name": "@houtini/lm-lite",
  "version": "2.0.0",
  "type": "module",
  "description": "Houtini LM Lite - Streamlined custom prompt execution with LM Studio",
  "main": "dist/index-lite.js",
  "bin": {
    "houtini-lm-lite": "dist/index-lite.js"
  },
  "scripts": {
    "build": "tsc && node add-shebang-lite.mjs",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/index-lite.js",
    "dev": "tsc --watch",
    "test:connection": "node test-connection.mjs"
  },
  "keywords": [
    "houtini",
    "local-lm",
    "mcp",
    "model-context-protocol",
    "claude-mcp",
    "lm-studio",
    "ai-development",
    "custom-prompts",
    "prompt-engineering",
    "task-offloading"
  ],
  "author": "Richard Baxter <richard@richardbaxter.co> (https://richardbaxter.co)",
  "license": "MIT",
  "homepage": "https://houtini.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/houtini-ai/lm.git"
  },
  "bugs": {
    "url": "https://github.com/houtini-ai/lm/issues"
  },
  "dependencies": {
    "@lmstudio/sdk": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.2"
  }
}
